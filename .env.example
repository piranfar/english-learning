# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.12.228

# Production security (when DJANGO_DEBUG=false)
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000

# Upload limits
# MAX_AUDIO_UPLOAD_BYTES=15728640
# DATA_UPLOAD_MAX_MEMORY_SIZE=20971520
# FILE_UPLOAD_MAX_MEMORY_SIZE=20971520

# Allow learners to pick AI provider in API requests (default: staff only)
# ALLOW_LEARNER_PROVIDER_OVERRIDE=false

# AI providers — local-first; Ollama is the default (no cloud keys required for dev)
DEFAULT_AI_PROVIDER=ollama

OLLAMA_HOST=http://127.0.0.1:11435
DEFAULT_OLLAMA_MODEL=qwen2.5:7b
FAST_OLLAMA_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Voice (STT / TTS) — browser TTS is default for listening; cloud optional
TRANSCRIPTION_PROVIDER=openai_whisper
TTS_PROVIDER=browser_tts
WHISPER_MODEL=whisper-1
LOCAL_WHISPER_MODEL=base
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# React dev / local network (optional)
FRONTEND_URL=http://localhost:5173
# FRONTEND_ORIGIN=http://192.168.1.42:5173
# EXTRA_CORS_ORIGINS=http://192.168.1.42:5173
